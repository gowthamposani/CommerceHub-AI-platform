APP_NAME=CommerceHub AI Platform
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/commercehub
SQLALCHEMY_ECHO=false

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_ISSUER=commercehub-ai
TOKEN_AUDIENCE=commercehub-web

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
