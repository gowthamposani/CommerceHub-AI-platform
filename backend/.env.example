APP_NAME=CommerceHub AI Platform
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

POSTGRES_DB=commercehub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/commercehub
SQLALCHEMY_ECHO=false

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_ISSUER=commercehub-ai
TOKEN_AUDIENCE=commercehub-web

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

REDIS_URL=redis://redis:6379/0

AI_PROVIDER=MOCK
GEMINI_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1
