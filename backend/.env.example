APP_NAME=CommerceHub AI
APP_ENV=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

POSTGRES_DB=commercehub_ai
POSTGRES_USER=commercehub
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://commercehub:change-me@postgres:5432/commercehub_ai

REDIS_URL=redis://redis:6379/0

AI_PROVIDER=MOCK
GEMINI_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1
