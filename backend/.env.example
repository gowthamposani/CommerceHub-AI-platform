APP_NAME=CommerceHub AI
APP_VERSION=0.1.0
APP_DESCRIPTION=Enterprise multi-vendor e-commerce platform
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
ALLOWED_HOSTS=localhost,127.0.0.1,backend

DATABASE_URL=postgresql+asyncpg://commercehub:commercehub@localhost:5432/commercehub
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

REDIS_URL=redis://localhost:6379/0
REDIS_HEALTH_TIMEOUT_SECONDS=2

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_DEFAULT_QUEUE=commercehub
CELERY_TASK_TIME_LIMIT_SECONDS=300
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=240

JWT_SECRET_KEY=change-me-in-environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

REQUEST_TIMEOUT_SECONDS=30
CORS_ENABLED=true
GZIP_ENABLED=true
GZIP_MINIMUM_SIZE=1000
TRUSTED_HOST_ENABLED=true
SECURITY_HEADERS_ENABLED=true

DOCKER_IMAGE=commercehub-ai-backend
